rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == "admin";
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAssignedTechnician(technicianId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/technicians/$(technicianId))
        && get(/databases/$(database)/documents/technicians/$(technicianId)).data.userId == request.auth.uid;
    }

    // Users: owner or admin can read; owners cannot read after soft-delete
    // (deletedAt field set). Hard-delete happens via Admin SDK (bypasses rules).
    match /users/{userId} {
      allow read: if (isOwner(userId) && !("deletedAt" in resource.data)) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.role == "user"
        && request.resource.data.displayName is string
        && request.resource.data.email is string;
      // Owners can update profile fields; admins can update anything.
      // Neither can directly set role or deletedAt — those go through API routes.
      allow update: if (isOwner(userId)
          && !("role" in request.resource.data.diff(resource.data).affectedKeys())
          && !("deletedAt" in request.resource.data.diff(resource.data).affectedKeys()))
        || isAdmin();
      allow delete: if isAdmin();

      match /notifications/{notificationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readAt"])
          && request.resource.data.readAt is string;
        allow create, delete: if false;
      }
    }

    match /technicians/{technicianId} {
      allow read: if (resource.data.isApproved == true && resource.data.isActive == true)
        || isAdmin()
        || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || (
          isAuthenticated()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.isApproved == resource.data.isApproved
          && request.resource.data.rating == resource.data.rating
          && request.resource.data.reviewCount == resource.data.reviewCount
        );
      allow delete: if isAdmin();
    }

    match /scooterBrands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /scooterModels/{modelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.userId == request.auth.uid)
        || isAssignedTechnician(resource.data.technicianId);
      allow create, update, delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.bookingId is string
        && request.resource.data.technicianId is string
        && request.resource.data.rating is int
        && request.resource.data.comment is string
        && exists(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId))
        && get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.technicianId == request.resource.data.technicianId
        && get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.status == "completed";
      allow update, delete: if false;
    }

    match /config/{docId} {
      allow read, write: if isAdmin();
    }

    match /paymentLinks/{docId} {
      allow read, write: if false;
    }

    match /auditLog/{docId} {
      allow read, write: if false;
    }

    match /webhookEvents/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
