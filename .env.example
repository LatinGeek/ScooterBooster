# ============================================================
# ScooterBooster — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any real credentials.
# ============================================================

# ------------------------------------------------------------
# Firebase Client SDK (public — safe to expose in browser)
# Get from: Firebase Console → Project Settings → Your apps → Web app
# ------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ------------------------------------------------------------
# Firebase Admin SDK (private — server-side only, never expose)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# FIREBASE_ADMIN_PRIVATE_KEY must be wrapped in double quotes with \n for newlines.
# ------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=""

# ------------------------------------------------------------
# MercadoPago
# Test credentials: https://www.mercadopago.com.uy/developers/panel/app
# Use TEST credentials for dev/preview, PROD credentials for production only.
# ------------------------------------------------------------
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
# Webhook secret: get from MP developer panel after registering the webhook URL
# Panel: https://www.mercadopago.com.uy/developers/panel/app → Your integrations → Webhooks
MERCADOPAGO_WEBHOOK_SECRET=

# ------------------------------------------------------------
# Email notifications (Resend)
# ------------------------------------------------------------
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=

# ------------------------------------------------------------
# Vercel MCP (for Alan's autonomous infra access)
# Get from: https://vercel.com/account/tokens
# ------------------------------------------------------------
VERCEL_MCP_TOKEN=

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://scooterbooster.uy
SERVICE_FEE_PERCENTAGE=10
NEXT_PUBLIC_USE_EMULATORS=false
NEXT_PUBLIC_GA_MEASUREMENT_ID=
CRON_SECRET=
